<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="OnLoad">
  <ribbon>
    <tabs>
      <tab id="tabLssOffice" label="LSS Office">
        <group id="grpHome" label="Home">
          <button id="btnDiagnostics" label="Diagnostics" size="large" imageMso="HappyFace" onAction="OnDiagnostics" />
        </group>
        <group id="grpBridge" label="Bridge">
          <button id="btnBridgeCodeSections" label="Bridge Code Sections" enabled="false" imageMso="TableOfContentsInsert" />
        </group>
        <group id="grpLegislative" label="Legislative">
          <button id="btnImportMeasure" label="Import Measure" enabled="false" imageMso="FileOpen" />
          <button id="btnCompareMeasures" label="Compare Measures" enabled="false" imageMso="ReviewCompareTwoVersions" />
        </group>
        <group id="grpAI" label="AI">
          <button id="btnSummarizeSelection" label="Summarize Selection" enabled="false" imageMso="SmartArtAddText" />
        </group>
        <group id="grpTools" label="Tools">
          <button id="btnOptions" label="Options" enabled="false" imageMso="FilePrepareMenu" />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
