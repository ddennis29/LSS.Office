<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui">
  <ribbon>
    <tabs>
      <tab id="tabLssHome" label="LSS">
        <group id="grpDiagnostics" label="Diagnostics">
          <button id="btnDiagnostics" label="Diagnostics" size="large" imageMso="Info" onAction="OnDiagnosticsClicked" getEnabled="IsEnabled" />
          <button id="btnInsertDiagnosticText" label="Insert Test Text" imageMso="TextBoxInsert" onAction="OnInsertDiagnosticTextClicked" getEnabled="IsEnabled" />
        </group>
        <group id="grpDeveloper" label="Developer">
          <button id="btnCommandBrowser" label="Command Browser" imageMso="ListMacros" onAction="OnCommandBrowserClicked" getEnabled="IsDeveloperEnabled" />
          <button id="btnSelectionInspector" label="Selection Inspector" imageMso="ResearchPane" onAction="OnSelectionInspectorClicked" getEnabled="IsDeveloperEnabled" />
          <button id="btnToggleDeveloperMode" label="Toggle Dev Mode" imageMso="ControlProperties" onAction="OnToggleDeveloperModeClicked" getEnabled="IsEnabled" />
        </group>
        <group id="grpBridge" label="Bridge">
          <button id="btnBridgeCodeSections" label="Bridge Code Sections" imageMso="TableOfContentsGallery" enabled="false" />
        </group>
        <group id="grpLegislative" label="Legislative">
          <button id="btnImportMeasure" label="Import Measure" imageMso="FileOpen" enabled="false" />
          <button id="btnCompareDocuments" label="Compare Documents" imageMso="ReviewCompareTwoVersions" enabled="false" />
        </group>
        <group id="grpAi" label="AI">
          <button id="btnSummarizeSelection" label="Summarize Selection" imageMso="ResearchPane" enabled="false" />
        </group>
        <group id="grpTools" label="Tools">
          <button id="btnSettings" label="Settings" imageMso="PropertySheet" enabled="false" />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
